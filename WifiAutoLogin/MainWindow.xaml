<Window x:Class="WifiAutoLogin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WifiAutoLogin"
        mc:Ignorable="d"
        Title="Wi-Fi Auto Login Assistant" Height="450" Width="600"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Text="Network Configuration" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Network List -->
        <ListBox x:Name="NetworksList" Grid.Row="1" Grid.Column="0" Margin="0,0,10,0" SelectionChanged="NetworksList_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Ssid}" FontWeight="SemiBold"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Edit Form -->
        <StackPanel Grid.Row="1" Grid.Column="1">
            <TextBlock Text="SSID:"/>
            <TextBox x:Name="TxtSsid" Margin="0,5,0,10" />

            <TextBlock Text="Username:"/>
            <TextBox x:Name="TxtUsername" Margin="0,5,0,10" />

            <TextBlock Text="Password:"/>
            <PasswordBox x:Name="TxtPassword" Margin="0,5,0,10" />

            <TextBlock Text="Login URL (Optional):"/>
            <TextBox x:Name="TxtLoginUrl" Margin="0,5,0,10" />

            <TextBlock Text="Username CSS Selector (Optional):"/>
            <TextBox x:Name="TxtUsernameSelector" Margin="0,5,0,10" />

            <TextBlock Text="Password CSS Selector (Optional):"/>
            <TextBox x:Name="TxtPasswordSelector" Margin="0,5,0,10" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button x:Name="BtnSave" Content="Save Config" Width="100" Height="30" Click="BtnSave_Click"/>
            </StackPanel>
        </StackPanel>

        <!-- Bottom Actions -->
        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,10,10,0">
            <Button x:Name="BtnAdd" Content="+" Width="30" Margin="0,0,5,0" Click="BtnAdd_Click"/>
            <Button x:Name="BtnRemove" Content="-" Width="30" Click="BtnRemove_Click"/>
        </StackPanel>
        
        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <CheckBox x:Name="ChkEnableLogging" Content="Enable Log Recording" VerticalAlignment="Center" Margin="0,0,10,0" Checked="ChkEnableLogging_Changed" Unchecked="ChkEnableLogging_Changed"/>
            <CheckBox x:Name="ChkAutoStart" Content="Run on Startup" VerticalAlignment="Center" Margin="0,0,10,0" Checked="ChkAutoStart_Changed" Unchecked="ChkAutoStart_Changed"/>
        </StackPanel>
    </Grid>
</Window>
