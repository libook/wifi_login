<Window x:Class="WifiAutoLogin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WifiAutoLogin"
        xmlns:services="clr-namespace:WifiAutoLogin.Services"
        mc:Ignorable="d"
        Title="{Binding [WindowTitle], Source={x:Static services:LocalizationManager.Instance}}" Height="600" Width="600" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Icon="WifiAutoLogin.ico">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding [HeaderTitle], Source={x:Static services:LocalizationManager.Instance}}" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Network List -->
        <ListBox x:Name="NetworksList" Grid.Row="1" Grid.Column="0" Margin="0,0,10,0" SelectionChanged="NetworksList_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Ssid}" FontWeight="SemiBold"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Edit Form -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="{Binding [SsidLabel], Source={x:Static services:LocalizationManager.Instance}}"/>
                <TextBox x:Name="TxtSsid" Margin="0,5,0,10" />

                <TextBlock Text="{Binding [UsernameLabel], Source={x:Static services:LocalizationManager.Instance}}"/>
                <TextBox x:Name="TxtUsername" Margin="0,5,0,10" />

                <TextBlock Text="{Binding [PasswordLabel], Source={x:Static services:LocalizationManager.Instance}}"/>
                <PasswordBox x:Name="TxtPassword" Margin="0,5,0,10" />

                <TextBlock Text="{Binding [LoginUrlLabel], Source={x:Static services:LocalizationManager.Instance}}"/>
                <TextBox x:Name="TxtLoginUrl" Margin="0,5,0,10" />

                <TextBlock Text="{Binding [UsernameSelectorLabel], Source={x:Static services:LocalizationManager.Instance}}"/>
                <TextBox x:Name="TxtUsernameSelector" Margin="0,5,0,10" />

                <TextBlock Text="{Binding [PasswordSelectorLabel], Source={x:Static services:LocalizationManager.Instance}}"/>
                <TextBox x:Name="TxtPasswordSelector" Margin="0,5,0,10" />

                <TextBlock Text="{Binding [LoginButtonSelectorLabel], Source={x:Static services:LocalizationManager.Instance}}"/>
                <TextBox x:Name="TxtLoginButtonSelector" Margin="0,5,0,10" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button x:Name="BtnTest" Content="{Binding [TestLoginButton], Source={x:Static services:LocalizationManager.Instance}}" Width="100" Height="30" Margin="0,0,10,0" Click="BtnTest_Click"/>
                    <Button x:Name="BtnSave" Content="{Binding [SaveConfigButton], Source={x:Static services:LocalizationManager.Instance}}" Width="100" Height="30" Click="BtnSave_Click"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Bottom Actions -->
        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,10,10,0">
            <Button x:Name="BtnAdd" Content="+" Width="30" Height="25" Margin="0,0,5,0" Click="BtnAdd_Click"/>
            <Button x:Name="BtnRemove" Content="-" Width="30" Height="25" Click="BtnRemove_Click"/>
        </StackPanel>
        
        <WrapPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                <TextBlock Text="{Binding [LanguageLabel], Source={x:Static services:LocalizationManager.Instance}}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="CmbLanguage" Width="80" VerticalAlignment="Center" SelectionChanged="CmbLanguage_Changed"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                <TextBlock Text="{Binding [NotificationLevelLabel], Source={x:Static services:LocalizationManager.Instance}}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="CmbNotificationLevel" Width="100" VerticalAlignment="Center" SelectionChanged="CmbNotificationLevel_Changed"/>
            </StackPanel>
            <CheckBox x:Name="ChkShowBrowser" Content="{Binding [ShowBrowserCheckBox], Source={x:Static services:LocalizationManager.Instance}}" VerticalAlignment="Center" Margin="0,0,15,5" Checked="ChkShowBrowser_Changed" Unchecked="ChkShowBrowser_Changed"/>
            <CheckBox x:Name="ChkEnableLogging" Content="{Binding [EnableLoggingCheckBox], Source={x:Static services:LocalizationManager.Instance}}" VerticalAlignment="Center" Margin="0,0,15,5" Checked="ChkEnableLogging_Changed" Unchecked="ChkEnableLogging_Changed"/>
            <CheckBox x:Name="ChkAutoStart" Content="{Binding [AutoStartCheckBox], Source={x:Static services:LocalizationManager.Instance}}" VerticalAlignment="Center" Margin="0,0,15,5" Checked="ChkAutoStart_Changed" Unchecked="ChkAutoStart_Changed"/>
        </WrapPanel>
    </Grid>
</Window>
